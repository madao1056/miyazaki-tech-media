---
import { Image } from "astro:assets";
import Divider from "@/components/bases/divider.astro";
import { getDateDistance, normalizeDate } from "@/lib/utils/date";
import { categoriesHandler } from "@/lib/handlers/categories";
import { getImageAlt, getArticleUrl } from "@/lib/utils/card";
import type { CardPropsWithFlags } from "@/lib/types";

type Props = CardPropsWithFlags;

const { article, isLast, isFirst } = Astro.props;

const category = categoriesHandler.oneCategory(article.data.category.id);
const imageAlt = getImageAlt(article);
const articleUrl = getArticleUrl(article.id);
---

<article
  class:list={[
    "group py-2 flex items-stretch gap-2 group relative isolate cursor-pointer",
    isFirst ? "pt-0" : "pt-2",
    isLast ? "border-b-0 pb-0" : "border-b border-base-300",
  ]}
>
  <div class="flex flex-col w-1/2">
    <h3 class="text-sm lg:group-hover:underline mb-1 line-clamp-3">
      <a href={articleUrl}>
        <span class="absolute inset-0 z-10"></span>
        {article.data.title}
      </a>
    </h3>
    <div class="flex items-center text-xs text-base-content/80 mt-auto">
      <span class="text-primary dark:text-secondary">{category.data.title}</span
      >
      <Divider />
      <span>{getDateDistance(normalizeDate(article.data.publishedTime))}</span>
    </div>
  </div>

  <div
    class="overflow-hidden w-1/2 aspect-video shrink-0"
  >
    <Image
      src={article.data.cover}
      alt={imageAlt}
      loading="eager"
      widths={[120, 320]}
      layout="constrained"
      class="object-cover rounded w-full h-full"
    />
  </div>
</article>
